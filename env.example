# Microsoft Rewards Script local settings
# Copy this file to .env and fill in your details.
# .env is ignored by git. Never commit credentials, cookies, tokens, or proxy passwords.

# Web UI port on the host machine.
WEB_UI_PORT=3000

# Optional: preconfigure Web admin login.
# Leave both empty to create the admin user on first browser visit.
WEB_ADMIN_USER=
WEB_ADMIN_PASSWORD=

# Microsoft account credentials are managed in the Web backend.
# The legacy ACCOUNT_N_* variables remain available only for one-time env import compatibility.

# Account 1 (legacy optional)
#ACCOUNT_1_EMAIL=you@example.com
#ACCOUNT_1_PASSWORD=<your-microsoft-password>
#ACCOUNT_1_TOTP_SECRET=
#ACCOUNT_1_RECOVERY_EMAIL=
#ACCOUNT_1_GEO_LOCALE=auto
#ACCOUNT_1_LANG_CODE=zh
#ACCOUNT_1_PROXY_AXIOS=false
#ACCOUNT_1_PROXY_URL=
#ACCOUNT_1_PROXY_PORT=0
#ACCOUNT_1_PROXY_USERNAME=
#ACCOUNT_1_PROXY_PASSWORD=

# Account 2 (legacy optional)
#ACCOUNT_2_EMAIL=second@example.com
#ACCOUNT_2_PASSWORD=<your-microsoft-password>
